# IBM Watsonx.ai — get from https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM Watsonx.ai Project ID — get from https://eu-de.dataplatform.cloud.ibm.com/projects
IBM_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx Orchestrate (optional — used if set, falls back to raw Granite above if not set
# or if the call fails). Get these from your Orchestrate instance: Settings -> API details,
# and the agent's own settings page for the agent ID.
# ORCHESTRATE_SERVICE_URL=https://api.eu-de.watson-orchestrate.cloud.ibm.com/instances/your-instance-id
# ORCHESTRATE_AGENT_ID=your_agent_id_here
# ORCHESTRATE_IAM_APIKEY=your_ibm_cloud_api_key_here

# Watson Text to Speech (optional — app falls back to browser TTS if not set)
# WATSON_TTS_API_KEY=your_watson_tts_api_key
# WATSON_TTS_URL=https://api.eu-de.text-to-speech.watson.cloud.ibm.com/instances/xxx
